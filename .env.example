# ─── Required ─────────────────────────────────────────────────────────────────

# Resend API key (https://resend.com)
# Obtain from: https://resend.com/api-keys
# Without this, form submissions are logged to console only (dev mode).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional ─────────────────────────────────────────────────────────────────

# Your public site URL (used for metadata and JSON-LD)
NEXT_PUBLIC_SITE_URL=https://udobots.com

# Google Analytics 4 Measurement ID (leave blank to disable)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible Analytics domain (leave blank to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=udobots.com
